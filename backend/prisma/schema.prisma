generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String?
  name          String
  country       String?
  skills        String?
  experience    String?
  linkedinUrl   String?
  portfolioUrl  String?
  avatarUrl     String?
  role          Role     @default(USER)
  provider      String?
  providerId    String?
  suspended     Boolean  @default(false)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  savedJobs        SavedJob[]
  flaggedJobs      FlaggedJob[]
  applications     Application[]
  projects         Project[]
  jobAlerts        JobAlert[]
  blogPosts        BlogPost[]
  cvUploads        CvUpload[]
}

enum Role {
  USER
  ADMIN
}

model Job {
  id          String   @id @default(uuid())
  externalId  String?
  title       String
  company     String
  location    String
  salary      String?
  category    String
  jobType     String
  source      String
  sourceUrl   String?
  description String
  postedAt    DateTime @default(now())
  logo        String?
  tags        String?
  verified    Boolean  @default(false)
  expired     Boolean  @default(false)
  sponsored   Boolean  @default(false)
  views       Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  savedBy     SavedJob[]
  flaggedBy   FlaggedJob[]

  @@unique([title, company, location])
  @@index([postedAt])
  @@index([category])
  @@index([jobType])
  @@index([expired])
  @@index([verified])
}

model SavedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
}

model FlaggedJob {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  reason    String?
  status    FlagStatus @default(PENDING)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

enum FlagStatus {
  PENDING
  SCAM
  DISMISSED
}

model Project {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  budget      String?
  skills      String
  duration    String?
  deadline    DateTime?
  status      ProjectStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]
}

enum ProjectStatus {
  PENDING
  APPROVED
  REJECTED
}

model Application {
  id        String   @id @default(uuid())
  userId    String
  projectId String
  message   String?
  status    AppStatus @default(PENDING)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

enum AppStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model JobAlert {
  id         String   @id @default(uuid())
  userId     String
  categories String
  keywords   String?
  jobTypes   String?
  frequency  String   @default("daily")
  active     Boolean  @default(true)
  lastSentAt DateTime?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BlogPost {
  id          String   @id @default(uuid())
  authorId    String
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model CvUpload {
  id           String   @id @default(uuid())
  userId       String
  filename     String
  atsScore     Int?
  missingKws   String?
  suggestions  String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AtsKeyword {
  id      String @id @default(uuid())
  keyword String @unique
  weight  Int    @default(1)
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
